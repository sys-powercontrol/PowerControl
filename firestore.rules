rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isMaster() {
      return isAuthenticated() &&
        (request.auth.token.email == "sys.powercontrol@gmail.com" ||
         getUserData().role == 'master');
    }

    function isAdmin() {
      return isAuthenticated() &&
        (isMaster() || getUserData().role == 'admin');
    }

    function hasPermission(permissionId) {
      return isMaster() || 
             (getUserData().role == 'admin') || 
             (getUserData().get('permissions', []).hasAny([permissionId]));
    }

    function belongsToCompany(companyId) {
      return isAuthenticated() && (isMaster() || getUserData().company_id == companyId);
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && (isOwner(userId) || isMaster() || (isAdmin() && resource.data.company_id == getUserData().company_id));
      allow create: if isAuthenticated() && (isMaster() || (isAdmin() && request.resource.data.get('company_id', null) == getUserData().get('company_id', null)) || !('company_id' in request.resource.data));
      allow update: if isAuthenticated() && 
        (isOwner(userId) || isAdmin()) && 
        (request.resource.data.get('role', resource.data.role) == resource.data.role || isAdmin()) &&
        (request.resource.data.get('permissions', resource.data.get('permissions', [])) == resource.data.get('permissions', []) || isAdmin()) &&
        (request.resource.data.get('company_id', resource.data.get('company_id', null)) == resource.data.get('company_id', null) || isMaster());
      allow delete: if isMaster();
    }

    match /products/{id} {
      allow read: if belongsToCompany(resource.data.company_id) && hasPermission('products.view');
      allow create: if belongsToCompany(request.resource.data.company_id) && hasPermission('products.manage');
      allow update: if belongsToCompany(resource.data.company_id) && belongsToCompany(request.resource.data.company_id) && hasPermission('products.manage');
      allow delete: if belongsToCompany(resource.data.company_id) && hasPermission('products.manage');
    }

    match /sales/{id} {
      allow read: if belongsToCompany(resource.data.company_id) && hasPermission('sales.view');
      allow create: if belongsToCompany(request.resource.data.company_id) && hasPermission('sales.create');
      allow update: if belongsToCompany(resource.data.company_id) && belongsToCompany(request.resource.data.company_id) && hasPermission('sales.create');
      allow delete: if belongsToCompany(resource.data.company_id) && hasPermission('sales.delete');
    }

    match /services/{id} {
      allow read: if belongsToCompany(resource.data.company_id) && hasPermission('products.view');
      allow create, update, delete: if belongsToCompany(request.resource.data.company_id) && hasPermission('products.manage');
    }

    match /clients/{id} {
      allow read: if belongsToCompany(resource.data.company_id) && hasPermission('sales.view');
      allow create, update, delete: if belongsToCompany(request.resource.data.company_id) && hasPermission('sales.create');
    }

    match /purchases/{id} {
      allow read, delete: if belongsToCompany(resource.data.company_id) && hasPermission('inventory.manage');
      allow create, update: if belongsToCompany(request.resource.data.company_id) && hasPermission('inventory.manage');
    }

    match /inventory_movements/{id} {
      allow read: if belongsToCompany(resource.data.company_id) && hasPermission('inventory.manage');
      allow create: if belongsToCompany(request.resource.data.company_id) && hasPermission('inventory.manage');
      allow update, delete: if false;
    }

    match /accountsPayable/{id} {
      allow read, delete: if belongsToCompany(resource.data.company_id) && hasPermission('finance.view');
      allow create: if belongsToCompany(request.resource.data.company_id) && (hasPermission('finance.manage') || hasPermission('inventory.manage'));
      allow update: if belongsToCompany(resource.data.company_id) && hasPermission('finance.manage');
    }

    match /accountsReceivable/{id} {
      allow read, delete: if belongsToCompany(resource.data.company_id) && hasPermission('finance.view');
      allow create: if belongsToCompany(request.resource.data.company_id) && (hasPermission('finance.manage') || hasPermission('sales.create'));
      allow update: if belongsToCompany(resource.data.company_id) && hasPermission('finance.manage');
    }

    match /bankAccounts/{id} {
      allow read, delete: if belongsToCompany(resource.data.company_id) && hasPermission('finance.view');
      allow create: if belongsToCompany(request.resource.data.company_id) && hasPermission('finance.manage');
      allow update: if belongsToCompany(resource.data.company_id) && (hasPermission('finance.manage') || hasPermission('sales.create') || hasPermission('inventory.manage'));
    }

    match /cashiers/{id} {
      allow read, delete: if belongsToCompany(resource.data.company_id) && hasPermission('finance.view');
      allow create: if belongsToCompany(request.resource.data.company_id) && hasPermission('finance.manage');
      allow update: if belongsToCompany(resource.data.company_id) && (hasPermission('finance.manage') || hasPermission('sales.create') || hasPermission('inventory.manage'));
    }

    match /suppliers/{id} {
      allow read, delete: if belongsToCompany(resource.data.company_id) && hasPermission('finance.view');
      allow create, update: if belongsToCompany(request.resource.data.company_id) && hasPermission('finance.manage');
    }

    match /sellers/{id} {
      allow read, delete: if belongsToCompany(resource.data.company_id) && hasPermission('sellers.manage');
      allow create, update: if belongsToCompany(request.resource.data.company_id) && hasPermission('sellers.manage');
    }

    match /employees/{id} {
      allow read, delete: if belongsToCompany(resource.data.company_id) && hasPermission('employees.manage');
      allow create, update: if belongsToCompany(request.resource.data.company_id) && hasPermission('employees.manage');
    }

    match /invoices/{id} {
      allow read, delete: if belongsToCompany(resource.data.company_id) && hasPermission('fiscal.manage');
      allow create, update: if belongsToCompany(request.resource.data.company_id) && hasPermission('fiscal.manage');
    }

    match /tax_rules/{id} {
      allow read, delete: if belongsToCompany(resource.data.company_id) && hasPermission('fiscal.manage');
      allow create, update: if belongsToCompany(request.resource.data.company_id) && hasPermission('fiscal.manage');
    }

    match /certificates/{id} {
      allow read, delete: if belongsToCompany(resource.data.company_id) && hasPermission('fiscal.manage');
      allow create, update: if belongsToCompany(request.resource.data.company_id) && hasPermission('fiscal.manage');
    }

    match /invites/{inviteId} {
      allow get: if true;
      allow list: if isAuthenticated() && (isMaster() || (isAdmin() && belongsToCompany(resource.data.company_id)));
      allow create: if isAuthenticated() && (isMaster() || (isAdmin() && getUserData().company_id == request.resource.data.company_id));
      allow update: if isAuthenticated() && (
        isMaster() || 
        (isAdmin() && getUserData().company_id == resource.data.company_id) ||
        (request.resource.data.status == 'ACCEPTED' && resource.data.status == 'PENDING')
      );
      allow delete: if isMaster();
    }

    match /audit_logs/{logId} {
      allow read: if isAuthenticated() && (isMaster() || hasPermission('audit.view'));
      allow create: if isAuthenticated() && request.resource.data.user_id == request.auth.uid;
      allow update, delete: if false;
    }

    match /support_tickets/{ticketId} {
      allow read: if isAuthenticated() && (isMaster() || resource.data.user_id == request.auth.uid || (isAdmin() && resource.data.company_id == getUserData().company_id));
      allow create: if isAuthenticated() && request.resource.data.user_id == request.auth.uid;
      allow update: if isAuthenticated() && (isMaster() || (resource.data.user_id == request.auth.uid && request.resource.data.status == resource.data.status));
      allow delete: if isMaster();
    }

    match /categories/{id} {
      allow read: if belongsToCompany(resource.data.company_id) && hasPermission('products.view');
      allow create, update, delete: if belongsToCompany(request.resource.data.company_id) && hasPermission('products.manage');
    }

    match /brands/{id} {
      allow read: if belongsToCompany(resource.data.company_id) && hasPermission('products.view');
      allow create, update, delete: if belongsToCompany(request.resource.data.company_id) && hasPermission('products.manage');
    }

    match /movements/{id} {
      allow read, delete: if belongsToCompany(resource.data.company_id) && hasPermission('finance.view');
      allow create: if belongsToCompany(request.resource.data.company_id) && (hasPermission('finance.manage') || hasPermission('sales.create') || hasPermission('inventory.manage'));
      allow update: if belongsToCompany(resource.data.company_id) && hasPermission('finance.manage');
    }

    match /companies/{companyId} {
      allow read: if isAuthenticated() && (isMaster() || getUserData().company_id == companyId);
      allow create: if isMaster();
      allow update: if isMaster() || (isAdmin() && getUserData().company_id == companyId);
      allow delete: if isMaster();
    }

    match /{path=**} {
      allow read, write: if false;
    }
  }
}
