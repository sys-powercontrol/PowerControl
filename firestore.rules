      allow update: if isValidId(id) && isValidAccount(incoming()) && (belongsToCompany(resource.data.company_id) && hasPermission('finance.manage')) && incoming().diff(existing()).affectedKeys().hasOnly(['description', 'amount', 'due_date', 'status', 'is_recurring', 'frequency', 'payment_date', 'receipt_date', 'bank_account_id', 'cashier_id', 'supplier', 'supplier_id', 'supplier_name', 'category_id', 'category_name', 'client_name'] && (existing().get('status', '') != 'Pago' || !incoming().diff(existing()).affectedKeys().hasAny(['amount', 'due_date', 'description']));
