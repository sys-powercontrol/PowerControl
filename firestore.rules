    function isValidInvoice(data) {
      return data.get('number', null) != null && (let data.number = data.number; data.number is number) &&
             (data.get('series', null) == null || (let data.series = data.series; data.series is string && val.size() <= 6000)) &&
             (data.get('type', null) == null || (let data.type = data.type; data.type is string && val.size() <= 6000)) &&
             (data.get('sale_id', null) == null || (let data.sale_id = data.sale_id; data.sale_id is string && val.size() <= 6000)) &&
             (data.get('client_name', null) == null || (let data.client_name = data.client_name; data.client_name is string && val.size() <= 6000)) &&
             (data.get('client_document', null) == null || (let data.client_document = data.client_document; data.client_document is string && val.size() <= 6000)) &&
             (data.get('total', null) == null || (let data.total = data.total; data.total is number)) &&
             data.get('status', null) != null && (let data.status = data.status; data.status is string && val.size() <= 6000) &&
             (data.get('emission_date', null) == null || (let data.emission_date = data.emission_date; data.emission_date is string && val.size() <= 6000)) &&
             (data.get('protocol', null) == null || (let data.protocol = data.protocol; data.protocol is string && val.size() <= 6000)) &&
             (data.get('access_key', null) == null || (let data.access_key = data.access_key; data.access_key is string && val.size() <= 6000)) &&
             (data.get('xml_url', null) == null || (let data.xml_url = data.xml_url; data.xml_url is string && val.size() <= 6000)) &&
             (data.get('xml_storage_url', null) == null || (let data.xml_storage_url = data.xml_storage_url; data.xml_storage_url is string && val.size() <= 6000)) &&
             (data.get('pdf_url', null) == null || (let data.pdf_url = data.pdf_url; data.pdf_url is string && val.size() <= 6000)) &&
             (data.get('error_message', null) == null || (let data.error_message = data.error_message; data.error_message is string && val.size() <= 6000)) &&
             data.get('company_id', null) != null && (let data.company_id = data.company_id; data.company_id is string && val.size() <= 6000) &&
             (data.get('created_at', null) == null || (let data.created_at = data.created_at; data.created_at is string && val.size() <= 6000));
    }

    function isValidSupportTicket(data) {
      return (data.get('company_id', null) == null || (let data.company_id = data.company_id; data.company_id is string && val.size() <= 6000)) &&
             data.get('user_id', null) != null && (let data.user_id = data.user_id; data.user_id is string && val.size() <= 6000) &&
             (data.get('user_name', null) == null || (let data.user_name = data.user_name; data.user_name is string && val.size() <= 6000)) &&
             (data.get('user_email', null) == null || (let data.user_email = data.user_email; data.user_email is string && val.size() <= 6000)) &&
             data.get('subject', null) != null && (let data.subject = data.subject; data.subject is string && val.size() <= 6000) &&
             data.get('message', null) != null && (let data.message = data.message; data.message is string && val.size() <= 6000) &&
             data.get('status', null) != null && (let data.status = data.status; data.status is string && val.size() <= 6000) &&
             (data.get('priority', null) == null || (let data.priority = data.priority; data.priority is string && val.size() <= 6000)) &&
             (data.get('internal_notes', null) == null || (let data.internal_notes = data.internal_notes; data.internal_notes is string && val.size() <= 6000)) &&
             (data.get('created_at', null) == null || (let data.created_at = data.created_at; data.created_at is string && val.size() <= 6000)) &&
             (data.get('updated_at', null) == null || (let data.updated_at = data.updated_at; data.updated_at is string && val.size() <= 6000));
    }


    function isAuthenticated() {
      return request.auth != null && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function getUserCompanyId() {
      return 'company_id' in request.auth.token ? request.auth.token.company_id : getUserData().company_id;
    }
    
    function getUserRole() {
      return 'role' in request.auth.token ? request.auth.token.role : getUserData().role;
    }
    
    function getUserPermissions() {
      return 'permissions' in request.auth.token ? request.auth.token.permissions : getUserData().get('permissions', []);
    }

    function isMaster() {
      return isAuthenticated() &&
        (request.auth.token.email == "sys.powercontrol@gmail.com" ||
         getUserRole() == 'master');
    }

    function isAdmin() {
      return isAuthenticated() &&
        (isMaster() || getUserRole() == 'admin');
    }

    function hasPermission(permissionId) {
      return isMaster() || 
             (getUserRole() == 'admin') || 
             (getUserPermissions().hasAny([permissionId]));
    }

    function belongsToCompany(companyId) {
      return isAuthenticated() && (isMaster() || getUserCompanyId() == companyId);
    }

    match /users/{userId} {
      allow read: if isValidId(userId) && (isAuthenticated() && (isOwner(userId) || isMaster() || (isAdmin() && resource.data.company_id == getUserCompanyId())));
      allow create: if isValidId(userId) && isValidUser(incoming()) && request.resource.data.keys().hasAll(['email', 'full_name', 'phone', 'document', 'role', 'company_id', 'permissions', 'active', 'created_at']) && request.resource.data.keys().size() == 9 && (isAuthenticated() && (isMaster() || (isAdmin() && request.resource.data.get('company_id', null) == getUserCompanyId()) || !('company_id' in request.resource.data)));
      allow update: if isAuthenticated() && 
        (isOwner(userId) || isAdmin()) && 
        (request.resource.data.get('role', resource.data.role) == resource.data.role || isAdmin()) &&
        (request.resource.data.get('permissions', resource.data.get('permissions', [])) == resource.data.get('permissions', []) || isAdmin()) &&
        (request.resource.data.get('company_id', resource.data.get('company_id', null)) == resource.data.get('company_id', null) || isMaster());
      allow delete: if isValidId(userId) && (isMaster());
    }

