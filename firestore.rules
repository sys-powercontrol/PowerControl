      allow update: if isValidId(id) && isValidMovement(incoming()) && (belongsToCompany(resource.data.company_id) && hasPermission('finance.manage')) && incoming().diff(existing()).affectedKeys().hasOnly(['type', 'description', 'amount', 'from_account_type', 'from_account_id', 'from_account_name', 'to_account_type', 'to_account_id', 'to_account_name', 'category', 'reconciliation_id', 'movement_date']);
