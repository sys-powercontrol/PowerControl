    match /companies/{companyId} {
      allow read: if isValidId(companyId) && (isAuthenticated() && (isMaster() || getUserCompanyId() == companyId));
      allow create: if isValidId(companyId) && isValidCompany(incoming()) && request.resource.data.keys().hasAll(['name', 'cnpj', 'address', 'phone', 'email', 'pix_key', 'logo_url', 'fiscal_token', 'fiscal_environment', 'fiscal_provider', 'role_permissions', 'active', 'created_at']) && request.resource.data.keys().size() == 13 && (isMaster());
      allow update: if isValidId(companyId) && isValidCompany(incoming()) && (isMaster() || (isAdmin() && getUserCompanyId() == companyId)) && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'cnpj', 'address', 'phone', 'email', 'pix_key', 'logo_url', 'fiscal_token', 'fiscal_environment', 'fiscal_provider', 'role_permissions', 'active']);
      allow delete: if isValidId(companyId) && (isMaster());
    }

    match /{path=**} {
      allow read, write: if false;
    }
  }
}