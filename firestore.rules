      allow update: if isValidId(id) && isValidProduct(incoming()) && (belongsToCompany(resource.data.company_id) && belongsToCompany(request.resource.data.company_id) && hasPermission('products.manage')) && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'sku', 'category_id', 'cost_price', 'sale_price', 'stock_quantity', 'min_stock', 'ncm', 'cest', 'icms_rate', 'ipi_rate', 'pis_rate', 'cofins_rate', 'mva_rate', 'csosn', 'cst', 'cfop', 'bom_items']);
