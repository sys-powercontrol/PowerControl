             (data.get('icms_rate', null) == null || (let data.icms_rate = data.icms_rate; data.icms_rate is number)) &&
             (data.get('ipi_rate', null) == null || (let data.ipi_rate = data.ipi_rate; data.ipi_rate is number)) &&
             (data.get('pis_rate', null) == null || (let data.pis_rate = data.pis_rate; data.pis_rate is number)) &&
             (data.get('cofins_rate', null) == null || (let data.cofins_rate = data.cofins_rate; data.cofins_rate is number)) &&
             (data.get('mva_rate', null) == null || (let data.mva_rate = data.mva_rate; data.mva_rate is number)) &&
             (data.get('csosn', null) == null || (let data.csosn = data.csosn; data.csosn is string && val.size() <= 6000)) &&
             (data.get('cst', null) == null || (let data.cst = data.cst; data.cst is string && val.size() <= 6000)) &&
             (data.get('cfop', null) == null || (let data.cfop = data.cfop; data.cfop is string && val.size() <= 6000)) &&
             data.get('company_id', null) != null && (let data.company_id = data.company_id; data.company_id is string && val.size() <= 6000) &&
             (data.get('bom_items', null) == null || (let data.bom_items = data.bom_items; data.bom_items is list && val.size() <= 1000)) &&
             (data.get('created_at', null) == null || (let data.created_at = data.created_at; data.created_at is string && val.size() <= 6000));
    }

    function isValidSale(data) {
      return (data.get('sale_number', null) == null || (let data.sale_number = data.sale_number; data.sale_number is string && val.size() <= 6000)) &&
