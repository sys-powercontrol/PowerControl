      allow update: if isValidId(id) && isValidService(incoming()) && (belongsToCompany(request.resource.data.company_id) && hasPermission('products.manage')) && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'description', 'price', 'category', 'iss_rate', 'pis_rate', 'cofins_rate', 'service_code', 'active']);
