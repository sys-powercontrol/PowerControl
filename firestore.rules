      allow update: if isValidId(id) && isValidSale(incoming()) && (belongsToCompany(resource.data.company_id) && belongsToCompany(request.resource.data.company_id) && hasPermission('sales.create')) && incoming().diff(existing()).affectedKeys().hasOnly(['sale_number', 'client_id', 'client_name', 'client_document', 'items', 'total', 'payment_method', 'cashier_id', 'seller_id', 'seller_name', 'commission_amount', 'commission_status']);
